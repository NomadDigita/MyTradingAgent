# Telegram
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_ALLOWED_USER_IDS=123456789

# Trading mode: paper or live. Keep paper until you have tested thoroughly.
TRADING_MODE=paper
APPROVAL_REQUIRED=true
MAX_LEVERAGE=20
DEFAULT_RISK_PER_TRADE=0.005
MAX_NOTIONAL_PER_TRADE=100
MAX_DAILY_LOSS=50

# Bitget / CCXT
BITGET_API_KEY=replace_me
BITGET_API_SECRET=replace_me
BITGET_API_PASSWORD=replace_me
BITGET_SANDBOX=false

# Optional persistence
DATABASE_URL=sqlite:///data/trading_agent.sqlite
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional auxiliary services
RISK_SERVICE_URL=
LOG_LEVEL=INFO
