###############################################################################
# MyTradingAgent environment draft
#
# Copy this file to .env for local use or copy the values into Render settings.
# Never commit real secrets. Rotate any token that has been exposed publicly.
###############################################################################

###############################################################################
# Telegram
###############################################################################

# Required. Create with BotFather. Use a fresh token for production.
TELEGRAM_BOT_TOKEN=replace_with_new_bot_token

# Required. Comma-separated Telegram numeric user IDs allowed to control the bot.
# Example: TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
TELEGRAM_ALLOWED_USER_IDS=123456789

###############################################################################
# Trading mode and approval
###############################################################################

# paper = simulated execution only.
# live  = submits real orders through the configured exchange adapter.
TRADING_MODE=paper

# Strongly recommended true. If true, /scan creates a pending plan and requires
# /approve <id> before execution.
APPROVAL_REQUIRED=true

###############################################################################
# Risk controls
###############################################################################

# Hard maximum leverage. Application code clamps leverage to 20 even if this is
# set higher.
MAX_LEVERAGE=20

# Fraction of account equity used as risk budget per generated trade plan.
# Conservative examples: 0.001 = 0.1%, 0.0025 = 0.25%, 0.005 = 0.5%.
DEFAULT_RISK_PER_TRADE=0.005

# Maximum notional size per trade plan.
MAX_NOTIONAL_PER_TRADE=100

# Daily realized-loss guard. New plans are blocked after this threshold.
MAX_DAILY_LOSS=50

# Maximum number of simultaneously open positions.
MAX_OPEN_POSITIONS=5

# Maximum notional exposure for one symbol across open positions plus new plan.
MAX_SYMBOL_NOTIONAL=250

# Maximum total portfolio notional exposure across open positions plus new plan.
MAX_PORTFOLIO_NOTIONAL=500

# Minimum research/strategy confidence before a plan can be built.
MIN_SIGNAL_CONFIDENCE=0.55

# Require every generated plan to include a stop loss.
REQUIRE_STOP_LOSS=true

# Pending approvals expire after this many minutes.
APPROVAL_EXPIRY_MINUTES=15

# Default symbols for /scan_many when no symbols are provided.
DEFAULT_SCAN_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT

###############################################################################
# Bitget / CCXT
###############################################################################

# Required only when TRADING_MODE=live.
# Use API keys with minimum required permissions and withdrawals disabled.
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSWORD=

# true for sandbox/testnet where supported by the exchange account/API.
BITGET_SANDBOX=false

###############################################################################
# Persistence
###############################################################################

# Where approvals/executions are persisted:
# - sqlite            : local SQLite file via DATABASE_URL
# - supabase_rest     : Supabase REST API via SUPABASE_URL + SUPABASE_SECRET_KEY
# - supabase_postgres : Supabase direct Postgres via SUPABASE_DIRECT_DATABASE_URL
# - none              : no database persistence
STORAGE_BACKEND=sqlite

# Local app database. Keep this as SQLite unless you intentionally wire a
# different backend through STORAGE_BACKEND.
DATABASE_URL=sqlite:///data/trading_agent.sqlite

# Optional Supabase REST storage.
#
# Supabase dashboard mapping:
# - Project URL / API URL        -> SUPABASE_URL
# - Publishable key / anon key   -> SUPABASE_PUBLISHABLE_KEY
# - Secret key / service_role    -> SUPABASE_SECRET_KEY
# - Direct connection string     -> SUPABASE_DIRECT_DATABASE_URL
#
# For STORAGE_BACKEND=supabase_rest:
#   set SUPABASE_URL and SUPABASE_SECRET_KEY, then run deployment/supabase_schema.sql.
#
# For STORAGE_BACKEND=supabase_postgres:
#   set SUPABASE_DIRECT_DATABASE_URL. The bot can create the required tables.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DIRECT_DATABASE_URL=

###############################################################################
# Optional auxiliary services
###############################################################################

# Optional Go risk service URL, for example: http://risk-service:8081
# Leave blank unless you deploy services/risk-go separately. The main Python
# app works without it.
RISK_SERVICE_URL=

# Append-only JSONL audit trail location.
AUDIT_LOG_PATH=logs/audit.jsonl

# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

###############################################################################
# Suggested profiles
###############################################################################

# Local paper testing:
# TRADING_MODE=paper
# APPROVAL_REQUIRED=true
# MAX_LEVERAGE=3
# DEFAULT_RISK_PER_TRADE=0.0025
# MAX_NOTIONAL_PER_TRADE=25
# MAX_DAILY_LOSS=25
# MAX_OPEN_POSITIONS=2
# MAX_SYMBOL_NOTIONAL=50
# MAX_PORTFOLIO_NOTIONAL=100

# Render paper deployment:
# TRADING_MODE=paper
# APPROVAL_REQUIRED=true
# MAX_LEVERAGE=5
# DEFAULT_RISK_PER_TRADE=0.005
# MAX_NOTIONAL_PER_TRADE=50
# MAX_DAILY_LOSS=50
# MAX_OPEN_POSITIONS=3
# MAX_SYMBOL_NOTIONAL=150
# MAX_PORTFOLIO_NOTIONAL=300

# Restricted live deployment:
# TRADING_MODE=live
# APPROVAL_REQUIRED=true
# MAX_LEVERAGE=10
# DEFAULT_RISK_PER_TRADE=0.0025
# MAX_NOTIONAL_PER_TRADE=50
# MAX_DAILY_LOSS=50
# MAX_OPEN_POSITIONS=3
# MAX_SYMBOL_NOTIONAL=150
# MAX_PORTFOLIO_NOTIONAL=300
